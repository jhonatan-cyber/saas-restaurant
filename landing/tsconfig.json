{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",
    "types": ["astro/client"],
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "astro.config.mjs"],
  "exclude": ["node_modules", "dist", ".astro"]
}
