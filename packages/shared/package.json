{
  "name": "@saas/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Tipos compartidos, esquemas Zod, enums y constantes para el SaaS Restaurant",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/enums.ts",
    "./schemas": "./src/schemas.ts",
    "./types": "./src/types.ts",
    "./constants": "./src/constants.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "echo 'shared is consumed via TS source — no build step needed'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
