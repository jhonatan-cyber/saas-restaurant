{
  "name": "@saas/admin",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend TanStack Start para el SaaS Restaurant",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000 --host 0.0.0.0",
    "build": "vite build",
    "start": "node serve.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .output .vite dist"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@saas/shared": "workspace:*",
    "@saas/ui": "workspace:*",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "@tanstack/react-start": "^1.168.19",
    "axios": "^1.8.0",
    "border-beam": "^1.3.0",
    "chart.js": "^4.5.1",
    "date-fns": "^4.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "sileo": "^0.1.5",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-devtools": "^1.167.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/axios": "^0.14.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
