// =============================================================================
// SaaS Restaurant — Prisma Schema
// =============================================================================
// MULTI-TENANT RULES (FUNDAMENTALES):
//  1. Business es el TENANT raíz. Ningún dato de negocio existe sin un
//     `businessId` apuntando a un Business.
//  2. La unicidad de email es POR BUSINESS, no global:
//       User: @@unique([businessId, email])
//     Esto permite que el mismo email exista en distintos tenants (caso
//     común: un dueño tiene varios restaurantes y usa el mismo email).
//  3. El login SIEMPRE requiere `businessSlug` + email + password. El slug
//     resuelve el tenant y luego el email se busca dentro de ese tenant.
//  4. Branch es opcional en Category/Product: si `branchId IS NULL` el
//     recurso es GLOBAL para todo el business; si tiene branch, solo aplica
//     a esa sucursal.
//  5. Todos los modelos llevan `createdAt`/`updatedAt` para auditoría.
//  6. Soft-delete: Category, Product, RestaurantTable y Customer usan
//     `deletedAt DateTime?`. Las queries deben filtrar `deletedAt: null`
//     salvo en admin/auditoría.
//  7. Phase 2 introduce `PreparationArea` (cocina/bar/cafetería) y
//     `TableStateLog` para historial de cambios de estado de mesa.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ============================ ENUMS ========================================

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  CAJERO
  MESERO
  COCINA
  REPARTIDOR
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum ProductType {
  SALE       // producto normal de venta
  COMBO      // combo de productos (Phase 2: modelado simple, items en fase futura)
  ADDON      // adicional / extra
  SERVICE    // servicio (ej. cover, parqueo)
  INGREDIENT // materia prima (no se vende directo, se usa en inventario)
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
}

enum TableLocation {
  INDOOR
  OUTDOOR
  BAR
  PATIO
  TERRACE
  OTHER
}

// ============================ Phase 3: ORDERS ============================
// Máquina de estados del pedido (D3=A: DRAFT reservado, primer estado
// persistido es PENDING). El orden importa para la UI.
enum OrderStatus {
  DRAFT              // RESERVADO — no se usa en F3 (carrito vive en frontend)
  PENDING            // recién creado, sin enviar a cocina
  SENT_TO_KITCHEN    // comandera impresa / KDS en pantalla
  IN_PREPARATION     // cocina aceptó y empezó
  READY              // listo para entregar
  DELIVERED          // entregado al cliente
  PAID               // pagado (terminal)
  CANCELLED          // cancelado (terminal, requiere userId + reason)
}

enum OrderType {
  DINE_IN    // en mesa
  TAKEOUT    // para llevar
  DELIVERY   // a domicilio
}

enum OrderChannel {
  POS_WEB      // POS desde el navegador
  POS_DESKTOP  // POS desde Tauri (F5)
  MOBILE       // app móvil (F5)
  KIOSK        // tótem de autoservicio (futuro)
  ADMIN        // carga manual desde backoffice
}

// Forward-compat para F4: módulo de caja (D1=A).
// Schema mínimo, sin CRUD en F3. El order valida OPEN cash + OPEN shift.
enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// ==================== FASE 4: Pagos ====================
enum PaymentMethod {
  CASH     // efectivo
  QR       // QR (pago móvil)
  TRANSFER // transferencia bancaria
  CARD     // tarjeta (POS físico)
}

// ==================== FASE 4: Movimientos de caja ====================
enum CashMovementType {
  CASH_IN
  CASH_OUT
}

enum CashMovementCategory {
  // Ingresos (no ventas)
  OWNER_INVESTMENT  // aporte del dueño
  SUPPLIER_REFUND   // devolución de proveedor
  LOAN_RECEIVED     // préstamo recibido
  TIP               // propina
  OTHER_IN

  // Egresos
  SUPPLIES          // insumos
  MAINTENANCE
  SALARY_ADVANCE
  RENT
  UTILITIES
  OWNER_WITHDRAWAL
  OTHER_OUT
}

// ==================== FASE 4: Auditoría ====================
enum AuditAction {
  CREATE
  UPDATE
  SOFT_DELETE
  HARD_DELETE
  VOID              // cancelaciones
  PRICE_CHANGE      // cambios de precio
  DISCOUNT          // descuentos aplicados
  SHIFT_OPEN
  SHIFT_CLOSE
  SHIFT_ARQUEO
  CASH_MOVEMENT
  PAYMENT
  STATION_ACTIVATE
  STATION_DEACTIVATE
}

// ==================== FASE 6: SaaS / Planes ====================
enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING
}

// ==================== FASE 6: Inventario ====================
enum InventoryMovementType {
  IN    // compras, ajustes positivos
  OUT   // ventas, mermas, ajustes negativos
  INITIAL  // carga de stock inicial
}

enum InventoryReferenceType {
  SALE
  PURCHASE
  ADJUSTMENT
  SPOILAGE
  INITIAL
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// ==================== FASE 6: Reportes ====================
enum ReportType {
  SALES_DAILY       // ventas del día
  SALES_RANGE       // ventas en un rango
  PAYMENT_METHODS   // desglose por método de pago
  TOP_PRODUCTS      // productos más vendidos
  GROSS_PROFIT      // utilidad bruta
  INVENTORY         // estado del inventario
  CLOSE_REPORT      // reporte de cierre
}

enum ReportFormat {
  PDF
  XLSX
}

enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ==================== PLAN / SUSCRIPCIÓN (F6: SaaS) ====================
// Los planes definen límites del sistema. Se asignan a un Business vía
// Subscription. El sistema bloquea creación de recursos si se exceden cuotas.
// Plan es global (sin businessId): el SaaS provider define los tiers.
model Plan {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code        String @db.VarChar(50)  @unique  // "FREE" | "BASIC" | "PRO" | "ENTERPRISE"
  name String @db.VarChar(80)
  description String?

  price          Decimal @default(0) @db.Decimal(10, 2)
  currency       String @db.VarChar(10)  @default("USD")
  billingPeriod  BillingPeriod @default(MONTHLY)

  // Límites del plan
  maxUsers          Int @default(1)
  maxBranches       Int @default(1)
  maxProducts       Int @default(50)
  maxCategories     Int @default(10)
  maxMonthlyOrders  Int @default(500)
  maxStorageMb      Int @default(100)

  // Features habilitadas (JSON array de strings)
  // ej: ["reports", "inventory", "kds", "multi_branch", "desktop_app", "mobile_app"]
  features Json @default("[]")

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  isPublic  Boolean @default(true)  // visible en el plan selector

  subscriptions Subscription[]
  businesses    Business[]

  @@map("plans")
}

// Suscripción de un Business a un Plan.
// Un business tiene UNA suscripción activa a la vez.
// El stripeSubscriptionId permite integración futura con pagos recurrentes.
model Subscription {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String @db.VarChar(80)
  planId String @db.VarChar(80)

  status SubscriptionStatus @default(TRIALING)

  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelledAt        DateTime?

  stripeSubscriptionId String?
  stripePriceId        String?
  stripeCustomerId     String?

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     Plan     @relation(fields: [planId], references: [id])

  @@unique([businessId])
  @@index([businessId, status])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

// ============================ MODELS =======================================

model Business {
  id        String @db.VarChar(80)         @id @default(cuid())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  name String @db.VarChar(80)
  slug        String        @unique
  legalName   String?
  taxId String? @db.VarChar(80)
  email String @db.VarChar(80)
  phone       String?
  logoUrl     String?
  currency    String @db.VarChar(10)        @default("BOB")
  timezone    String @db.VarChar(50)        @default("America/La_Paz")
  status      BusinessStatus @default(ACTIVE)
  plan        String @db.VarChar(20)        @default("FREE") // deprecado en F6, usar relación con Plan
  trialEndsAt DateTime?                        // deprecado en F6

  // Feature flags locales (pueden sobreescribir límites del plan)
  // null = usa el límite del plan; true/false = override
  overrideMaxUsers         Int?    // null = usar del plan
  moduleReports            Boolean @default(false)
  moduleInventory          Boolean @default(false)
  modulePosStations        Boolean @default(false)
  moduleDeliveryApp        Boolean @default(false)

  // Relations
  branches           Branch[]
  users              User[]
  categories         Category[]
  products           Product[]
  preparationAreas   PreparationArea[]
  tables             RestaurantTable[]
  customers          Customer[]
  tableStateLogs     TableStateLog[]
  orders             Order[]
  orderItems         OrderItem[]
  orderStateLogs     OrderStateLog[]
  cashRegisters      CashRegister[]
  shifts             Shift[]
  payments           Payment[]
  cashMovements      CashMovement[]
  auditLogs          AuditLog[]
  posStations        PosStation[]
  planRef            Plan?            @relation(fields: [planId], references: [id])
  planId String? @db.VarChar(80)
  subscription       Subscription?
  suppliers          Supplier[]
  purchases          Purchase[]
  inventoryMovements InventoryMovement[]
  reports            Report[]

  @@index([slug])
  @@index([status])
  @@index([planId])
  @@map("businesses")
}

model Branch {
  id        String @db.VarChar(80)       @id @default(cuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  businessId String @db.VarChar(80)
  name String @db.VarChar(80)
  code String @db.VarChar(80)
  address    String?
  phone      String?
  isMain     Boolean      @default(false)
  status     BranchStatus @default(ACTIVE)

  // Relations
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  users            User[]            @relation("UserDefaultBranch")
  categories       Category[]
  products         Product[]
  preparationAreas PreparationArea[]
  tables           RestaurantTable[]
  orders           Order[]
  cashRegisters    CashRegister[]
  shifts           Shift[]
  cashMovements    CashMovement[]
  posStations      PosStation[]
  suppliers        Supplier[]
  purchases        Purchase[]
  inventoryMovements InventoryMovement[]

  // Code único por business (cada sucursal tiene su propio código)
  @@unique([businessId, code])
  @@index([businessId])
  @@map("branches")
}

model User {
  id        String @db.VarChar(80)     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  email String @db.VarChar(80)
  passwordHash String
  fullName     String
  phone        String?
  avatarUrl    String?
  role         Role       @default(CAJERO)
  status       UserStatus @default(INVITED)

  businessId String @db.VarChar(80)
  defaultBranchId String? @db.VarChar(80)

  lastLoginAt DateTime?

  // Relations
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  defaultBranch Branch?  @relation("UserDefaultBranch", fields: [defaultBranchId], references: [id], onDelete: SetNull)

  // Back-relations Phase 3: orders como cajero y como mesero.
  ordersAsCashier Order[] @relation("OrderCashier")
  ordersAsWaiter  Order[] @relation("OrderWaiter")

  // Back-relations FASE 4
  paymentsCreated      Payment[]      @relation("PaymentCashier")
  cashMovementsCreated CashMovement[] @relation("CashMovementCreator")
  auditLogs            AuditLog[]     @relation("AuditUser")

  // Back-relations FASE 5
  posStationsActivated PosStation[] @relation("PosStationActivator")

  // Back-relations FASE 6
  purchasesCreated Purchase[] @relation("PurchaseCreator")
  reportsRequested Report[]   @relation("ReportRequester")

  // Back-relations from Cash (FASE 3/4)
  shiftsOwned           Shift[]        @relation("ShiftUser")
  cashRegistersOpened   CashRegister[] @relation("CashRegisterOpener")
  cashRegistersClosed   CashRegister[] @relation("CashRegisterCloser")

  // MULTI-TENANT: email único por business (no global)
  @@unique([businessId, email])
  @@index([businessId, role])
  @@index([businessId, status])
  @@map("users")
}

model Category {
  id        String @db.VarChar(80)    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  businessId String @db.VarChar(80)
  branchId String? @db.VarChar(80)

  name String @db.VarChar(80)
  slug String @db.VarChar(50)
  description String?
  imageUrl    String?

  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  // Relations
  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products Product[]

  // Nota MySQL: branchId NULL se trata como DISTINTO, así que múltiples
  // categorías "globales" con el mismo slug NO se bloquearán. Validar a
  // nivel de aplicación si se necesita restricción dura.
  @@unique([businessId, branchId, slug])
  @@index([businessId, displayOrder])
  @@index([businessId, isActive])
  @@index([businessId, deletedAt])
  @@map("categories")
}

model Product {
  id        String @db.VarChar(80)    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  businessId String @db.VarChar(80)
  branchId String? @db.VarChar(80)
  categoryId String? @db.VarChar(80)
  preparationAreaId String? @db.VarChar(80)

  name String @db.VarChar(80)
  slug String @db.VarChar(80)
  description String?
  imageUrl    String?

  sku String? @db.VarChar(80)

  price    Decimal  @db.Decimal(12, 2)
  cost     Decimal? @db.Decimal(12, 2)
  taxRate  Decimal? @db.Decimal(5, 2)

  isActive     Boolean @default(true)
  isAvailable  Boolean @default(true)

  minStock    Int?
  trackStock  Boolean @default(false)

  // FASE 6: Stock tracking
  currentStock Decimal @default(0) @db.Decimal(12, 2)

  // Phase 2: tipo de producto y tiempo estimado de preparación
  productType        ProductType @default(SALE)
  preparationTimeMin Int?

  // F5-01: Items del combo (JSON array de { productId, productName, quantity })
  // Ej: [{ "productId": "...", "productName": "Hamburguesa", "quantity": 1 }]
  comboItems Json?

  // F5-02: Precios por cantidad (JSON array de { minQty, unitPrice })
  // Ej: [{ "minQty": 6, "unitPrice": 8.50 }, { "minQty": 12, "unitPrice": 7.00 }]
  bulkPricing Json?

  // Relations
  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch          Branch?          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  preparationArea PreparationArea? @relation(fields: [preparationAreaId], references: [id], onDelete: SetNull)

  suppliers        Supplier[]
  purchaseItems    PurchaseItem[]
  inventoryMovements InventoryMovement[]

  @@unique([businessId, slug])
  @@index([businessId, categoryId])
  @@index([businessId, isActive])
  @@index([businessId, sku])
  @@index([businessId, productType])
  @@index([businessId, deletedAt])
  @@map("products")
}

// ==================== Phase 2: nuevas entidades ====================

model PreparationArea {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String @db.VarChar(80)
  branchId String? @db.VarChar(80)

  name String @db.VarChar(80)
  code String @db.VarChar(80)
  description String?
  isActive    Boolean @default(true)
  displayOrder Int    @default(0)

  // Relations
  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([businessId, code])
  @@index([businessId, displayOrder])
  @@index([businessId, isActive])
  @@map("preparation_areas")
}

// ==================== FASE 6: Proveedores (Inventario) ====================
// Un proveedor puede tener múltiples productos que suministra.
// La relación es M:N vía la tabla implícita en Product.suppliers (a través de
// SupplierProduct, agregada como array en ambos lados).
model Supplier {
  id        String @db.VarChar(80)    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  businessId String @db.VarChar(80)
  branchId String? @db.VarChar(80)

  name String @db.VarChar(50)
  contactName String?
  email String? @db.VarChar(80)
  phone       String?
  address     String?
  taxId String? @db.VarChar(80)
  notes       String?

  isActive Boolean @default(true)

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  products Product[]
  purchases Purchase[]

  @@unique([businessId, branchId, name])
  @@index([businessId, isActive])
  @@map("suppliers")
}

// ==================== FASE 6: Compras (Inventario) ====================
// Una compra agrupa items recibidos de un proveedor.
// status: PENDING = pedido, COMPLETED = recibido, CANCELLED = anulado.
// Al completar se crean InventoryMovement por cada item.
model Purchase {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String @db.VarChar(80)
  branchId String @db.VarChar(80)
  supplierId String? @db.VarChar(80)

  purchaseNumber String  // número de orden interno o factura
  status         PurchaseStatus @default(PENDING)

  // Totales
  subtotal  Decimal @default(0) @db.Decimal(14, 2)
  taxTotal  Decimal @default(0) @db.Decimal(14, 2)
  total     Decimal @default(0) @db.Decimal(14, 2)

  notes         String?
  receivedAt    DateTime?
  receivedBy    String? @db.VarChar(80)  // userId
  invoiceUrl    String?  // URL de factura/PDF subido

  // Relations
  business  Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier  Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy User          @relation("PurchaseCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdById String @db.VarChar(80)

  items PurchaseItem[]

  @@index([businessId, branchId, createdAt])
  @@index([businessId, status])
  @@index([supplierId])
  @@map("purchases")
}

// Ítem individual de compra. Snapshot de precio al momento de comprar.
// Al completar la compra se genera un InventoryMovement por item.
model PurchaseItem {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())

  purchaseId String @db.VarChar(80)
  productId String? @db.VarChar(80)

  // Snapshot
  productName String
  unitCost    Decimal @db.Decimal(12, 2)
  quantity    Decimal @db.Decimal(12, 2)  // soporta decimales (ej: 1.5 kg)
  lineTotal   Decimal @db.Decimal(14, 2)

  // Relations
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

// ==================== FASE 6: Movimientos de inventario (Kardex) =========
// Cada movimiento registra entrada/salida de un producto.
// referenceType + referenceId vinculan al documento origen.
// El saldo (runningBalance) es el balance acumulado después del movimiento.
// Se registran en orden cronológico y se recalcula al detectar inconsistencias.
model InventoryMovement {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())

  businessId String @db.VarChar(80)
  branchId String @db.VarChar(80)
  productId String @db.VarChar(80)

  type    InventoryMovementType  @default(IN)
  referenceType InventoryReferenceType
  referenceId   String? @db.VarChar(80)  // ID del documento origen: Purchase.id, OrderItem.id, etc.

  // Cantidades
  quantity Decimal @db.Decimal(12, 2)  // positiva para IN, negativa para OUT
  unitCost Decimal? @db.Decimal(12, 2) // costo unitario al momento del movimiento
  totalCost Decimal? @db.Decimal(14, 2) // quantity * unitCost

  // Saldo después del movimiento (para kardex)
  runningBalance Decimal @db.Decimal(12, 2)

  notes String?

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId, createdAt])
  @@index([businessId, branchId, createdAt])
  @@index([referenceType, referenceId])
  @@index([businessId, createdAt])
  @@map("inventory_movements")
}

model RestaurantTable {
  id        String @db.VarChar(80)    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  businessId String @db.VarChar(80)
  branchId String @db.VarChar(80)

  number String @db.VarChar(50)
  capacity     Int           @default(4)
  location     TableLocation @default(INDOOR)
  status       TableStatus   @default(FREE)
  isActive     Boolean       @default(true)
  displayOrder Int           @default(0)
  notes        String?
  posX         Int?
  posY         Int?

  // Relations
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch     Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stateLogs  TableStateLog[]
  orders     Order[]

  @@unique([businessId, branchId, number])
  @@index([businessId, branchId, status])
  @@index([branchId, displayOrder])
  @@index([businessId, deletedAt])
  @@map("restaurant_tables")
}

model TableStateLog {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())

  businessId String @db.VarChar(80)
  tableId String @db.VarChar(80)
  previousStatus   TableStatus
  newStatus        TableStatus
  changedByUserId String @db.VarChar(80)
  reason           String?

  // Relations
  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  table    RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId, createdAt])
  @@index([businessId, createdAt])
  @@map("table_state_logs")
}

model Customer {
  id        String @db.VarChar(80)    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  businessId String @db.VarChar(80)

  name String @db.VarChar(80)
  taxId String? @db.VarChar(80)
  taxIdType       String? @db.VarChar(20)
  email String? @db.VarChar(80)
  phone           String?
  address         String?
  addressReference String?
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  notes           String?

  isActive     Boolean  @default(true)
  totalOrders  Int      @default(0)
  totalSpent   Decimal  @default(0) @db.Decimal(14, 2)
  lastOrderAt  DateTime?

  // Loyalty points (FASE 7: Programa de fidelización)
  loyaltyPoints       Int @default(0)  // Puntos actuales disponibles
  loyaltyPointsEarned Int @default(0)  // Total de puntos ganados históricamente

  // Relations
  business           Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orders             Order[]
  loyaltyRedemptions LoyaltyRedemption[]

  @@index([businessId, loyaltyPoints])

  @@index([businessId, isActive])
  @@index([businessId, name])
  @@index([businessId, taxId])
  @@index([businessId, deletedAt])
  @@map("customers")
}

// ==================== Phase 3: Orders ====================
// Reglas de diseño críticas (R3, R4, R7, R8 del SDD):
//  - State machine: OrderStatus es enum (hint TS) pero la transición la
//    valida `order-state-machine.ts` en el service. NUNCA aceptar status
//    arbitrario en PATCH.
//  - Optimistic lock: `version` se incrementa en cada update. El cliente
//    recibe 409 si su `version` está desfasado y debe reintentar.
//  - Snapshot: OrderItem guarda productName/unitPrice/taxRate/areaId
//    al momento de crear. Cambios posteriores en Product NO alteran items.
//  - Cash (D1=A): cashRegisterId y shiftId se setean al crear.
//  - Table auto-state (R7): OrdersService es source of truth. El service
//    cambia RestaurantTable.status a OCCUPIED al primer order PENDING
//    y a FREE cuando todos los orders activos están PAID/CANCELLED.
model Order {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String @db.VarChar(80)
  branchId   String @db.VarChar(80)  // SIEMPRE presente: toda orden es de una sucursal concreta

  tableId    String? @db.VarChar(80)  // null para TAKEOUT/DELIVERY
  customerId String? @db.VarChar(80)

  cashierId String @db.VarChar(80)  // userId que abre la orden (del JWT al crear)
  waiterId  String? @db.VarChar(80) // userId del mesero (asignable después)

  type    OrderType    @default(DINE_IN)
  channel OrderChannel @default(POS_WEB)
  status  OrderStatus  @default(PENDING)

  // Totales recalculados server-side en tx (R4). Decimals como string en DTO.
  subtotal Decimal @db.Decimal(14, 2)
  taxTotal Decimal @default(0) @db.Decimal(14, 2)
  total    Decimal @db.Decimal(14, 2)

  globalNotes String?

  // Forward-compat F4 (D1=A): FK a sesión de caja abierta al crear.
  cashRegisterId String? @db.VarChar(80)
  shiftId String? @db.VarChar(80)

  // Optimistic lock (R4)
  version Int @default(0)

  // Cancelación inmutable (R6): userId + reason obligatorios al cancelar.
  cancelledAt        DateTime?
  cancelledByUserId String? @db.VarChar(80)
  cancellationReason String?

  // FASE 7: Discount / Loyalty
  discount       Decimal @default(0) @db.Decimal(14, 2)  // Descuento aplicado
  discountReason String?                                  // Motivo del descuento

  // Relations
  business       Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch         Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table          RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customer       Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cashier        User             @relation("OrderCashier", fields: [cashierId], references: [id], onDelete: Restrict)
  waiter         User?            @relation("OrderWaiter", fields: [waiterId], references: [id], onDelete: SetNull)
  cashRegister   CashRegister?    @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  shift          Shift?           @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  items      OrderItem[]
  stateLogs  OrderStateLog[]
  payments   Payment[]

  // Índices pensados para las queries calientes:
  //  - (business, branch, status) → KDS filtrado por estado
  //  - (business, branch, tableId, status) → ver pedidos activos de una mesa
  //  - (business, createdAt) → listado cronológico
  @@index([businessId, branchId, status])
  @@index([businessId, branchId, tableId, status])
  @@index([businessId, createdAt])
  @@index([businessId, branchId, createdAt])
  @@index([businessId, cashierId, createdAt])
  @@map("orders")
}

// Snapshot inmutable (R8). NO guardar FKs a Product como únicas fuentes:
// si el product se edita o se soft-deletea, el item debe seguir intacto.
model OrderItem {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())

  businessId String @db.VarChar(80)
  orderId String @db.VarChar(80)

  // Opcional: si el product es hard-eliminado (no debería pasar por soft-delete),
  // queda null pero el snapshot sigue válido.
  productId String? @db.VarChar(80)

  // ===== SNAPSHOT (R8): columnas planas, NO relaciones =====
  productName          String
  unitPrice            Decimal  @db.Decimal(12, 2)
  taxRate              Decimal? @db.Decimal(5, 2)
  preparationAreaId String? @db.VarChar(80)
  preparationAreaName  String?
  // =======================================================

  quantity   Int
  notes      String?  // observación por ítem (ej: "sin sal", "término medio")
  lineTotal  Decimal  @db.Decimal(14, 2)  // = unitPrice * quantity (snapshot)

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([businessId, orderId])
  // Para KDS: encontrar todos los items de un área de preparación
  @@index([businessId, preparationAreaId])
  @@map("order_items")
}

// Historial inmutable de transiciones de estado. R3 + auditoría.
model OrderStateLog {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())

  businessId String @db.VarChar(80)
  orderId String @db.VarChar(80)

  fromStatus  OrderStatus?
  toStatus    OrderStatus
  changedByUserId String @db.VarChar(80)
  reason      String?
  metadata    Json?

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([businessId, createdAt])
  @@map("order_state_logs")
}

// ==================== Phase 3: Cash Foundation (D1=A) ====================
// Schema mínimo forward-compatible con F4. En F3 NO hay CRUD; solo lectura
// desde OrdersService para validar OPEN cash + OPEN shift antes de crear.
model CashRegister {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String @db.VarChar(80)
  branchId String @db.VarChar(80)
  code String @db.VarChar(50)
  status     CashRegisterStatus @default(OPEN)

  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  openedByUserId String @db.VarChar(80)
  closedByUserId String? @db.VarChar(80)

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shifts   Shift[]
  orders   Order[]
  openedBy User     @relation("CashRegisterOpener", fields: [openedByUserId], references: [id], onDelete: Restrict)
  closedBy User?    @relation("CashRegisterCloser", fields: [closedByUserId], references: [id], onDelete: SetNull)

  @@unique([businessId, branchId, code])
  @@index([businessId, branchId, status])
  @@map("cash_registers")
}

model Shift {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String @db.VarChar(80)
  branchId String @db.VarChar(80)
  cashRegisterId String @db.VarChar(80)
  userId         String @db.VarChar(80)  // cajero dueño del turno

  status ShiftStatus @default(OPEN)

  openedAt       DateTime @default(now())
  closedAt       DateTime?
  openingAmount  Decimal  @db.Decimal(14, 2)  // base de caja
  closingAmount  Decimal? @db.Decimal(14, 2)  // lo que contó el cajero al cerrar
  expectedAmount Decimal? @db.Decimal(14, 2)  // lo que el sistema esperaba
  difference     Decimal? @db.Decimal(14, 2)  // diferencia (closing - expected)

  // Notes al cerrar (opcional): "faltante por error de cambio", etc.
  closingNotes String?

  // Relations
  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  user         User         @relation("ShiftUser", fields: [userId], references: [id], onDelete: Restrict)
  orders       Order[]
  movements    CashMovement[]

  // Solo puede haber UN shift OPEN por (cashRegister, user) simultáneamente
  @@index([businessId, branchId, status])
  @@index([cashRegisterId, status])
  @@index([userId, status])
  @@map("shifts")
}

// ==================== FASE 4: Pagos (1-N con Order) ====================
// Cada Payment acredita una parte del total. Pagos mixtos = N Payment rows.
// El Order pasa a PAID cuando Σ(payments.amount) >= order.total.
model Payment {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())

  businessId String @db.VarChar(80)
  orderId String @db.VarChar(80)
  method     PaymentMethod

  // amount: lo que se acredita al order (NETO).
  // Para CASH: amount = order total asignado a este pago.
  //             tendered = lo que entregó el cliente, change = vuelto.
  // Para QR/TRANSFER/CARD: amount = cobrado, reference = comprobante.
  amount    Decimal  @db.Decimal(14, 2)
  tendered  Decimal? @db.Decimal(14, 2)  // CASH: lo entregado por el cliente
  change    Decimal? @db.Decimal(14, 2)  // CASH: vuelto
  reference String?                       // QR/TRANSFER: número de comprobante

  cashierId String @db.VarChar(80)  // userId que registró el cobro

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  cashier  User     @relation("PaymentCashier", fields: [cashierId], references: [id], onDelete: Restrict)

  @@index([businessId, orderId])
  @@index([businessId, createdAt])
  @@index([cashierId, createdAt])
  @@index([businessId, method, createdAt])
  @@map("payments")
}

// ==================== FASE 4: Movimientos de caja ====================
// Egresos/Ingresos no relacionados a ventas. Vinculados opcionalmente a un
// shift abierto. Si NO tienen shift, son movimientos directos del business
// (ej. aporte de capital del dueño cuando aún no hay turno).
model CashMovement {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())

  businessId String @db.VarChar(80)
  branchId String @db.VarChar(80)
  shiftId    String? @db.VarChar(80)  // null = movimiento sin turno (ej. aporte inicial)

  type     CashMovementType
  category CashMovementCategory
  amount   Decimal @db.Decimal(14, 2)
  reason   String?  // descripción libre

  createdByUserId String @db.VarChar(80)

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shift    Shift?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  user     User     @relation("CashMovementCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([businessId, branchId, createdAt])
  @@index([shiftId])
  @@index([createdByUserId, createdAt])
  @@index([businessId, type, createdAt])
  @@map("cash_movements")
}

// ==================== FASE 4: Auditoría ====================
// Log inmutable de cambios. Intercepta:
//  - Cambios de precio (Product.price)
//  - Cancelaciones (Order → CANCELLED)
//  - Soft-deletes
//  - Apertura/cierre de shifts
//  - Movimientos de caja
//  - Pagos
// before/after son snapshots JSON del entity modificado.
model AuditLog {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())

  businessId String @db.VarChar(80)
  userId String @db.VarChar(80)

  entity   String @db.VarChar(50)      // "Product" | "Order" | "Shift" | "CashMovement" | "Payment"
  entityId String @db.VarChar(80)
  action   AuditAction

  before   Json?  // snapshot anterior (UPDATE, SOFT_DELETE, VOID, PRICE_CHANGE)
  after    Json?  // snapshot nuevo (CREATE, UPDATE)
  metadata Json?  // contexto extra (ip, userAgent, reason, etc)

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation("AuditUser", fields: [userId], references: [id], onDelete: Restrict)

  @@index([businessId, entity, entityId])
  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@index([businessId, action, createdAt])
  @@map("audit_logs")
}

// ================= FASE 5: Estaciones POS (Desktop) =================

model PosStation {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String @db.VarChar(80)
  branchId String @db.VarChar(80)

  // Station identity
  stationCode String @db.VarChar(80)  // código de activación (6-8 chars, ingresa el usuario)
  name        String? // nombre amigable ej. "Caja Principal"
  deviceName  String? // hostname detectado automáticamente

  // Activation
  activatedAt DateTime?
  activatedBy String? @db.VarChar(80)  // userId que activó la estación
  lastSeenAt  DateTime?
  isActive    Boolean  @default(true)

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user     User?    @relation("PosStationActivator", fields: [activatedBy], references: [id], onDelete: SetNull)

  @@unique([businessId, stationCode])
  @@index([businessId, branchId])
  @@index([businessId, isActive])
  @@map("pos_stations")
}

// ==================== FASE 7: Programa de Fidelización ====================
// Configuración del programa de puntos por negocio.
// Cada business define sus propias reglas.
model LoyaltyProgram {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String @db.VarChar(80)  @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  enabled            Boolean @default(true)
  pointsPerCurrency  Decimal @default(10) @db.Decimal(10, 2)  // 1 punto por cada X de moneda (ej. Bs 10)
  pointValue         Decimal @default(0.50) @db.Decimal(10, 2) // Valor en descuento de cada punto
  minRedeemPoints    Int     @default(10)                     // Mínimo de puntos para canjear
  maxRedeemPerOrder  Int?                                     // Máximo por orden (null = sin límite)
  autoAward          Boolean @default(true)                   // Otorgar puntos automáticamente al pagar

  @@map("loyalty_programs")
}

// Historial de canjes de puntos de un cliente.
model LoyaltyRedemption {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())

  businessId String @db.VarChar(80)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  customerId String @db.VarChar(80)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  orderId String @db.VarChar(80)
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  pointsUsed     Int     // Puntos canjeados
  discountAmount Decimal @db.Decimal(14, 2)  // Descuento otorgado = pointsUsed * pointValue al momento
  notes          String?

  @@index([customerId, createdAt])
  @@index([orderId])
  @@map("loyalty_redemptions")
}

// ==================== FASE 6: Reportes ====================
// Cola de generación de reportes. Un usuario solicita un reporte,
// BullMQ lo procesa en background, y el resultado (PDF/XLSX) se guarda
// en storage. El frontend puede consultar el status y descargar.
model Report {
  id        String @db.VarChar(80)   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String @db.VarChar(80)
  requestedBy String @db.VarChar(80)

  type       ReportType
  format     ReportFormat @default(PDF)
  status     ReportStatus @default(PENDING)

  // Parámetros de generación (JSON opaco)
  // ej: { "dateFrom": "2026-01-01", "dateTo": "2026-06-01", "branchId": "..." }
  params Json @default("{}")

  // Resultados
  resultUrl    String?  // URL del archivo generado
  resultSize   Int?     // tamaño en bytes
  errorMessage String?
  completedAt  DateTime?
  expiresAt    DateTime? // auto-limpieza después de 7 días

  // Relations
  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  requester User     @relation("ReportRequester", fields: [requestedBy], references: [id], onDelete: Restrict)

  @@index([businessId, createdAt])
  @@index([businessId, status])
  @@index([businessId, requestedBy])
  @@map("reports")
}
