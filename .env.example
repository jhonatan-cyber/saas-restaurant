# ============================================================
# SaaS Restaurant - Environment Variables
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
# ============================================================

# -- Infrastructure -------------------------------------------
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=saas_restaurant

# -- API (NestJS) --------------------------------------------
DATABASE_URL=mysql://root:rootpass@localhost:3306/saas_restaurant
REDIS_URL=redis://localhost:6379
API_PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
JWT_SECRET=dev-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-key-change-in-production
LOG_LEVEL=debug

# -- Admin (TanStack Start / Vite) ---------------------------
VITE_API_URL=http://localhost:3001/api
VITE_API_BASE_URL=http://localhost:3001

# -- Print Agent ----------------------------------------------
API_URL=http://localhost:3001
PRINTER_NAME=POS-80
PRINT_AGENT_PORT=3002
PRINTERS_JSON=./print-agent/printers.json

# -- Stripe --------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
API_PUBLIC_URL=http://localhost:3001

# -- General -------------------------------------------------
NODE_ENV=development
