# =============================================================================
# SaaS Restaurant — Environment Variables Example
# Copy this file to `.env` and adjust values for your local setup.
# =============================================================================

# ----- General ----------------------------------------------------------------
NODE_ENV=development

# ----- API (NestJS) -----------------------------------------------------------
API_PORT=3001
API_GLOBAL_PREFIX=api
API_CORS_ORIGIN=http://localhost:3000

# ----- Web (TanStack Start) ---------------------------------------------------
WEB_PORT=3000
VITE_API_URL=http://localhost:3001/api
VITE_API_BASE_URL=http://localhost:3001
# Database Configuration Development
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=saas_restaurant
DB_PORT=3306

# ----- Database (MySQL 8) -----------------------------------------------------
# Matches the docker-compose service "mysql"
DATABASE_URL="mysql://saas_app:saas_dev_2026@127.0.0.1:3306/saas_restaurant"

# ----- Redis 7 ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----- JWT --------------------------------------------------------------------
# IMPORTANT: replace these with strong random values in production.
# Generate with: `openssl rand -base64 64`
JWT_SECRET=change-me-jwt-access-secret-please-use-a-strong-random-value
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret-please-use-a-strong-random-value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----- Print Agent (placeholder for Phase 5) ----------------------------------
PRINT_AGENT_PORT=4050
PRINT_AGENT_URL=http://localhost:4050
