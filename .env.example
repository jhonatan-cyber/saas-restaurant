# ============================================================
# SaaS Restaurant - Environment Variables
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
# ============================================================

# -- Database (MySQL) ------------------------------------------
# Individual connection variables (reemplazan la cadena directa)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=saas_restaurant
MYSQL_ROOT_PASSWORD=

# DATABASE_URL hardcodeada porque .env no expande ${} vars.
# Prisma la requiere en este formato para migraciones y runtime.
# Si tu root tiene contraseña, actualizá este valor.
DATABASE_URL=mysql://root@localhost:3306/saas_restaurant

# -- Redis -----------------------------------------------------
REDIS_URL=redis://localhost:6379

# -- Ports de servicios ----------------------------------------
# Cada proyecto usa su propia variable de puerto.
API_PORT=3001           # API (NestJS)
APP_PORT=3000           # App (TanStack Start — panel operativo)
ADMIN_PORT=3003         # Admin (TanStack Start — panel SUPER_ADMIN)
PRINT_AGENT_PORT=3002   # Print Agent (Hono)
LANDING_PORT=4321       # Landing (Astro)

# -- API (NestJS) --------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3003
JWT_SECRET=dev-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-key-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
LOG_LEVEL=debug
API_GLOBAL_PREFIX=api
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
DISABLE_WS=false

# -- Reports --------------------------------------------------
REPORTS_STORAGE_DIR=./uploads/reports
REPORTS_BASE_URL=/uploads/reports

# -- App (TanStack Start) -------------------------------------
VITE_API_URL=http://localhost:3001/api
VITE_API_BASE_URL=http://localhost:3001

# -- Print Agent ----------------------------------------------
API_URL=http://localhost:3001
PRINTER_NAME=POS-80
PRINTERS_JSON=./print-agent/printers.json
PRINT_AGENT_URL=http://localhost:3002

# -- Stripe --------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
API_PUBLIC_URL=http://localhost:3001

# -- General -------------------------------------------------
NODE_ENV=development
