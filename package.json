{
  "name": "saas-restaurant",
  "private": true,
  "version": "0.1.0",
  "description": "Gastronomic POS / SaaS multi-tenant platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,admin -c blue,magenta \"bun run dev:api\" \"bun run dev:admin\"",
    "dev:api": "bun run --filter @saas/api start:dev",
    "dev:admin": "bun run --filter @saas/admin dev",
    "dev:landing": "bun run --filter @saas/landing dev",
    "build": "turbo run build",
    "build:api": "bun run --filter @saas/api build",
    "build:admin": "bun run --filter @saas/admin build",
    "build:landing": "bun run --filter @saas/landing build",
    "db:generate": "bun run --filter @saas/api db:generate",
    "db:migrate": "bun run --filter @saas/api db:migrate",
    "db:seed": "bun run --filter @saas/api db:seed",
    "db:reset": "bun run --filter @saas/api db:reset",
    "lint": "turbo run lint",
    "format": "prettier --write \"{apps,packages}/*/src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"{apps,packages}/*/src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:api": "bun run --filter @saas/api test",
    "test:e2e": "bun run --filter @saas/api test:e2e",
    "test:admin": "bun run --filter @saas/admin test",
    "test:print-agent": "cd apps/print-agent && bun test",
    "clean": "bun run --filter '*' clean",
    "postinstall": "node -e \"var fs=require('fs'),p='node_modules/jest-environment-node/node_modules/jest-mock';if(fs.existsSync(p)){fs.rmSync(p,{recursive:true,force:true})}\""
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "turbo": "^2.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=22.12.0"
  },
  "overrides": {
    "jest-mock": "^30.4.1"
  },
  "packageManager": "bun@1.3.11"
}
