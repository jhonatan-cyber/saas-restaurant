{
  "name": "saas-restaurant",
  "private": true,
  "version": "0.1.0",
  "description": "Gastronomic POS / SaaS multi-tenant platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun run --filter @saas/api start:dev",
    "dev:web": "bun run --filter @saas/web dev",
    "build": "bun run --filter '*' build",
    "build:api": "bun run --filter @saas/api build",
    "build:web": "bun run --filter @saas/web build",
    "db:generate": "bun run --filter @saas/api db:generate",
    "db:migrate": "bun run --filter @saas/api db:migrate",
    "db:seed": "bun run --filter @saas/api db:seed",
    "db:reset": "bun run --filter @saas/api db:reset",
    "lint": "eslint \"{apps,packages}/*/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{apps,packages}/*/src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"{apps,packages}/*/src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run test:unit && bun run test:web && bun run test:print-agent",
    "test:unit": "bun run --filter @saas/api test",
    "test:e2e": "bun run --filter @saas/api test:e2e",
    "test:web": "bun run --filter @saas/web test",
    "test:print-agent": "cd apps/print-agent && bun test",
    "clean": "bun run --filter '*' clean"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "concurrently": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.11"
}
